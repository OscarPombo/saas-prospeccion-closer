---
import Layout from '../../layouts/Layout.astro';

const token = Astro.url.searchParams.get('token') || '';
const telegramLink = token ? `https://t.me/oscar_prospeccion_bot?start=${token}` : null;
---
<Layout title="¡Bienvenido! — Soplo">
  <main class="min-h-screen flex flex-col items-center justify-center px-4">
    <div class="max-w-md w-full text-center space-y-8">
      <div class="space-y-3">
        <div class="text-5xl">🎉</div>
        <h1 class="text-3xl font-bold text-gray-900">¡Ya estás dentro!</h1>
        <p class="text-gray-500">Tu perfil de tono ha sido creado. Solo falta conectar tu Telegram.</p>
      </div>

      <div class="bg-indigo-50 rounded-2xl p-6 text-center space-y-4">
        <p class="font-semibold text-indigo-900">Último paso — conecta Telegram:</p>
        {telegramLink ? (
          <a
            href={telegramLink}
            class="block w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3.5 rounded-xl transition-colors"
          >
            Abrir Telegram y vincular →
          </a>
        ) : (
          <p class="text-sm text-red-600">No se encontró tu enlace de vinculación. Vuelve a intentar el registro o escríbenos.</p>
        )}
        <p class="text-xs text-indigo-700">Se abrirá tu chat con el bot, ya con el mensaje listo — solo tienes que pulsar enviar.</p>
        <p class="text-xs text-indigo-400">Mañana a las 8:00 recibirás tus primeros leads.</p>
      </div>

      <p class="text-sm text-gray-400">
        ¿Alguna duda? Escríbenos a
        <a href="mailto:opombo84@gmail.com" class="text-indigo-600 hover:underline">opombo84@gmail.com</a>
      </p>

      <a href="/" class="text-sm text-gray-400 hover:text-gray-600 transition-colors">← Volver al inicio</a>
    </div>
  </main>
</Layout>
