---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Registro — Soplo">
  <main class="min-h-screen flex flex-col items-center justify-center px-4 py-12">
    <div class="max-w-md w-full bg-white rounded-2xl shadow-sm border border-gray-100 p-8 space-y-6">

      <!-- Barra de progreso -->
      <div class="flex items-center gap-2" id="progress">
        <div class="h-1.5 flex-1 rounded-full bg-indigo-600" id="bar1"></div>
        <div class="h-1.5 flex-1 rounded-full bg-gray-200" id="bar2"></div>
        <div class="h-1.5 flex-1 rounded-full bg-gray-200" id="bar3"></div>
      </div>

      <!-- Paso 1: Perfil -->
      <div id="step1" class="space-y-5">
        <div>
          <h2 class="text-xl font-bold text-gray-900">Tu perfil</h2>
          <p class="text-sm text-gray-500 mt-1">Datos básicos para crear tu cuenta.</p>
        </div>
        <div class="space-y-1">
          <label class="block text-sm font-medium text-gray-700">Nombre</label>
          <input id="name" type="text" placeholder="Tu nombre" class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div class="space-y-1">
          <label class="block text-sm font-medium text-gray-700">Email</label>
          <input id="email" type="email" placeholder="tu@email.com" class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div class="space-y-1">
          <label class="block text-sm font-medium text-gray-700">Username de Telegram</label>
          <input id="telegram" type="text" placeholder="@tunombre" class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" />
        </div>
        <div class="space-y-2">
          <label class="block text-sm font-medium text-gray-700">Región de prospectos</label>
          <div class="grid grid-cols-3 gap-2">
            <button type="button" data-region="spain" class="region-btn py-2 px-3 rounded-lg border border-gray-200 text-sm font-medium text-gray-600 hover:border-gray-300 transition-colors">🇪🇸 España</button>
            <button type="button" data-region="latam" class="region-btn py-2 px-3 rounded-lg border border-gray-200 text-sm font-medium text-gray-600 hover:border-gray-300 transition-colors">🌎 LATAM</button>
            <button type="button" data-region="both" class="region-btn py-2 px-3 rounded-lg border border-indigo-600 bg-indigo-50 text-sm font-medium text-indigo-700 transition-colors">🌍 Ambas</button>
          </div>
        </div>
        <div class="space-y-2">
          <label class="block text-sm font-medium text-gray-700">Nichos de infoproductores</label>
          <p class="text-xs text-gray-400">Selecciona hasta 5 nichos. <span id="niche-count" class="font-medium text-indigo-600">0 seleccionados</span></p>
          <div id="niches-container" class="space-y-3 max-h-72 overflow-y-auto pr-1"></div>
        </div>
        <button id="next1" class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 rounded-xl transition-colors">
          Siguiente →
        </button>
      </div>

      <!-- Paso 2: Audio -->
      <div id="step2" class="space-y-5 hidden">
        <div>
          <h2 class="text-xl font-bold text-gray-900">Tu voz</h2>
          <p class="text-sm text-gray-500 mt-1">Grabamos tu tono para que los mensajes suenen como tú.</p>
        </div>
        <div class="bg-indigo-50 rounded-xl p-4 space-y-2 text-sm text-indigo-800">
          <p class="font-semibold">Grábate 60–90 segundos respondiendo en voz alta:</p>
          <ol class="list-decimal list-inside space-y-1 text-indigo-700">
            <li>¿Cómo te presentas cuando contactas a alguien nuevo?</li>
            <li>¿Cómo explicas lo que haces a un infoproductor?</li>
            <li>¿Cómo sueles empezar una conversación de ventas?</li>
          </ol>
          <p class="text-indigo-600 text-xs mt-2">Habla natural, como si fuera una nota de voz.</p>
        </div>
        <div id="dropzone" class="border-2 border-dashed border-gray-300 hover:border-indigo-400 rounded-xl p-6 text-center cursor-pointer transition-colors">
          <p class="text-gray-500 text-sm" id="drop-label">Pulsa para subir tu audio</p>
          <p class="text-gray-400 text-xs mt-1">.mp3, .m4a, .wav, .ogg · Max 25 MB</p>
        </div>
        <input id="audio" type="file" accept="audio/*" class="hidden" />
        <div class="flex gap-3">
          <button id="back2" class="flex-1 py-3 rounded-xl border border-gray-200 text-gray-600 font-medium hover:bg-gray-50 transition-colors">← Atrás</button>
          <button id="next2" class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 rounded-xl transition-colors">Siguiente →</button>
        </div>
      </div>

      <!-- Paso 3: Confirmación -->
      <div id="step3" class="space-y-5 hidden">
        <div>
          <h2 class="text-xl font-bold text-gray-900">Todo listo</h2>
          <p class="text-sm text-gray-500 mt-1">Revisa y confirma tu registro.</p>
        </div>
        <div id="summary" class="bg-gray-50 rounded-xl p-4 space-y-2 text-sm text-gray-700"></div>
        <div class="flex gap-3">
          <button id="back3" class="flex-1 py-3 rounded-xl border border-gray-200 text-gray-600 font-medium hover:bg-gray-50 transition-colors">← Atrás</button>
          <button id="submit" class="flex-1 bg-indigo-600 hover:bg-indigo-700 disabled:opacity-60 text-white font-semibold py-3 rounded-xl transition-colors">Activar cuenta →</button>
        </div>
      </div>

      <p id="error" class="text-sm text-red-600 text-center hidden"></p>
    </div>
  </main>
</Layout>

<script>
  let currentStep = 1;
  let selectedRegion = 'both';
  let selectedNiches: string[] = [];
  let audioFile: File | null = null;

  const regionLabels: Record<string, string> = { spain: '🇪🇸 España', latam: '🌎 LATAM', both: '🌍 Ambas' };
  const NICHES: { category: string; items: { slug: string; name: string; active: boolean }[] }[] = [
    { category: '🤖 IA', items: [
      { slug: 'ia-aplicada', name: 'IA aplicada a negocios y automatización', active: true },
    ]},
    { category: '💼 Negocios', items: [
      { slug: 'ecommerce-saas',           name: 'Ecommerce, Amazon FBA y micro-SaaS',          active: true },
      { slug: 'agencias-consultoria-b2b', name: 'Agencias y consultoría B2B',                  active: true },
      { slug: 'closers-lanzamientos',     name: 'Formación para closers y lanzamientos',       active: true },
      { slug: 'compra-venta-lifestyle',   name: 'Compra-venta de negocios y lifestyle business', active: true },
    ]},
    { category: '📱 Marketing', items: [
      { slug: 'funnels-copywriting', name: 'Embudos de venta y copywriting',              active: true },
      { slug: 'trafico-pagado-seo',  name: 'Tráfico pagado y SEO',                        active: true },
      { slug: 'contenido-organico',  name: 'Contenido orgánico (redes, YouTube, email)',  active: true },
    ]},
    { category: '💰 Finanzas', items: [
      { slug: 'trading-bolsa',          name: 'Trading e inversión en bolsa',                          active: true },
      { slug: 'inversion-inmobiliaria', name: 'Inversión inmobiliaria',                                active: true },
      { slug: 'finanzas-alternativas',  name: 'Finanzas alternativas (cripto, ángel, libertad financiera)', active: true },
    ]},
    { category: '🧠 Desarrollo', items: [
      { slug: 'mentalidad-liderazgo',   name: 'Mentalidad, alto rendimiento y liderazgo', active: true },
      { slug: 'productividad-oratoria', name: 'Productividad y oratoria',                 active: true },
    ]},
    { category: '💪 Salud', items: [
      { slug: 'fitness-composicion',   name: 'Fitness y composición corporal', active: true },
      { slug: 'longevidad-biohacking', name: 'Longevidad y biohacking',        active: true },
      { slug: 'salud-mental',          name: 'Salud mental y burnout',         active: true },
    ]},
    { category: '❤️ Relaciones', items: [
      { slug: 'relaciones-bienestar', name: 'Coaching de relaciones y bienestar femenino', active: true },
      { slug: 'seduccion-masculina',  name: 'Seducción masculina',                          active: true },
    ]},
    { category: '✨ Espiritualidad', items: [
      { slug: 'coaching-espiritual', name: 'Coaching espiritual y transformacional', active: true },
    ]},
    { category: '🎯 Skills', items: [
      { slug: 'coaches-cobrar-mas',         name: 'Coaches que quieren cobrar más', active: true },
      { slug: 'musica-produccion',          name: 'Música y producción musical',    active: true },
      { slug: 'coaching-ejecutivo-c-level', name: 'Coaching ejecutivo C-level',     active: true },
    ]},
  ];

  // Renderizar nichos
  const container = document.getElementById('niches-container')!;
  NICHES.forEach(cat => {
    const catEl = document.createElement('div');
    catEl.innerHTML = `<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-1">${cat.category}</p>`;
    const grid = document.createElement('div');
    grid.className = 'grid grid-cols-2 gap-1.5';
    cat.items.forEach(item => {
      const btn = document.createElement('button');
      btn.type = 'button';
      if (item.active) {
        btn.dataset.niche = item.slug;
        const isSelected = selectedNiches.includes(item.slug);
        btn.className = `niche-btn py-2 px-2.5 rounded-lg border text-xs font-medium text-left transition-colors ${isSelected ? 'border-indigo-600 bg-indigo-50 text-indigo-700' : 'border-gray-200 text-gray-600 hover:border-gray-300'}`;
        btn.textContent = item.name;
      } else {
        btn.disabled = true;
        btn.className = 'py-2 px-2.5 rounded-lg border border-gray-100 bg-gray-50 text-xs text-gray-400 text-left cursor-not-allowed';
        btn.innerHTML = `${item.name}<span class="block text-gray-300 font-normal">Próximamente</span>`;
      }
      grid.appendChild(btn);
    });
    catEl.appendChild(grid);
    container.appendChild(catEl);
  });

  const nicheLabels: Record<string, string> = Object.fromEntries(
    NICHES.flatMap(c => c.items.map(i => [i.slug, i.name]))
  );

  function showStep(step: number) {
    [1, 2, 3].forEach(s => {
      document.getElementById(`step${s}`)!.classList.toggle('hidden', s !== step);
      const bar = document.getElementById(`bar${s}`) as HTMLElement;
      bar.className = `h-1.5 flex-1 rounded-full ${s <= step ? 'bg-indigo-600' : 'bg-gray-200'}`;
    });
    currentStep = step;
  }

  function showError(msg: string) {
    const el = document.getElementById('error')!;
    el.textContent = msg;
    el.classList.remove('hidden');
    setTimeout(() => el.classList.add('hidden'), 3000);
  }

  // Región
  document.querySelectorAll('.region-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      selectedRegion = (btn as HTMLElement).dataset.region!;
      document.querySelectorAll('.region-btn').forEach(b => {
        b.className = 'region-btn py-2 px-3 rounded-lg border border-gray-200 text-sm font-medium text-gray-600 hover:border-gray-300 transition-colors';
      });
      btn.className = 'region-btn py-2 px-3 rounded-lg border border-indigo-600 bg-indigo-50 text-sm font-medium text-indigo-700 transition-colors';
    });
  });

  function updateNicheCount() {
    document.getElementById('niche-count')!.textContent = `${selectedNiches.length} seleccionado${selectedNiches.length !== 1 ? 's' : ''}`;
  }

  document.getElementById('niches-container')!.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.niche-btn') as HTMLButtonElement | null;
    if (!btn || btn.disabled) return;
    const niche = btn.dataset.niche!;
    if (selectedNiches.includes(niche)) {
      if (selectedNiches.length === 0) return;
      selectedNiches = selectedNiches.filter(n => n !== niche);
      btn.className = 'niche-btn py-2 px-2.5 rounded-lg border border-gray-200 text-xs font-medium text-gray-600 text-left transition-colors hover:border-gray-300';
    } else {
      if (selectedNiches.length >= 5) { showError('Máximo 5 nichos.'); return; }
      selectedNiches.push(niche);
      btn.className = 'niche-btn py-2 px-2.5 rounded-lg border border-indigo-600 bg-indigo-50 text-xs font-medium text-indigo-700 text-left transition-colors';
    }
    updateNicheCount();
  });

  // Paso 1 → 2
  document.getElementById('next1')!.addEventListener('click', () => {
    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const telegram = (document.getElementById('telegram') as HTMLInputElement).value.trim();
    if (!name || !email || !telegram) { showError('Rellena todos los campos.'); return; }
    if (selectedNiches.length === 0) { showError('Selecciona al menos un nicho.'); return; }
    showStep(2);
  });

  // Audio upload
  const dropzone = document.getElementById('dropzone')!;
  const audioInput = document.getElementById('audio') as HTMLInputElement;
  dropzone.addEventListener('click', () => audioInput.click());
  audioInput.addEventListener('change', () => {
    audioFile = audioInput.files?.[0] || null;
    if (audioFile) document.getElementById('drop-label')!.textContent = `✓ ${audioFile.name}`;
  });

  // Paso 2 → 3
  document.getElementById('back2')!.addEventListener('click', () => showStep(1));
  document.getElementById('next2')!.addEventListener('click', () => {
    if (!audioFile) { showError('Sube tu audio primero.'); return; }
    const name = (document.getElementById('name') as HTMLInputElement).value.trim();
    const email = (document.getElementById('email') as HTMLInputElement).value.trim();
    const telegram = (document.getElementById('telegram') as HTMLInputElement).value.trim();
    document.getElementById('summary')!.innerHTML = `
      <p><span class="font-medium">Nombre:</span> ${name}</p>
      <p><span class="font-medium">Email:</span> ${email}</p>
      <p><span class="font-medium">Telegram:</span> ${telegram}</p>
      <p><span class="font-medium">Región:</span> ${regionLabels[selectedRegion]}</p>
      <p><span class="font-medium">Nichos:</span> ${selectedNiches.map(n => nicheLabels[n] || n).join(', ')}</p>
      <p><span class="font-medium">Audio:</span> ✓ ${audioFile.name}</p>
    `;
    showStep(3);
  });

  // Paso 3 → envío
  document.getElementById('back3')!.addEventListener('click', () => showStep(2));
  document.getElementById('submit')!.addEventListener('click', async () => {
    const btn = document.getElementById('submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Procesando…';

    const data = new FormData();
    data.append('name', (document.getElementById('name') as HTMLInputElement).value.trim());
    data.append('email', (document.getElementById('email') as HTMLInputElement).value.trim());
    data.append('telegram', (document.getElementById('telegram') as HTMLInputElement).value.trim());
    data.append('region', selectedRegion);
    data.append('niches', JSON.stringify(selectedNiches));
    data.append('audio', audioFile!);

    try {
      const res = await fetch('/api/onboarding', { method: 'POST', body: data });
      const json = await res.json();
      if (!res.ok) throw new Error(json.error || 'Error al procesar');
      window.location.href = '/onboarding/success';
    } catch (e: unknown) {
      showError(e instanceof Error ? e.message : 'Error inesperado');
      btn.disabled = false;
      btn.textContent = 'Activar cuenta →';
    }
  });
</script>
